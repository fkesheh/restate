{
  "name": "restate",
  "description": "Injects a reminder to restate questions in fully concrete terms before answering. Improves grounding on ambiguous prompts.",
  "author": {
    "name": "Foad Kesheh",
    "url": "https://github.com/fkesheh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/restate.sh\"",
            "timeout": 5,
            "statusMessage": "Injecting restate reminder..."
          }
        ]
      }
    ]
  }
}
